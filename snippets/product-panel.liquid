{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_default_variant = product.metafields.custom.default_sku.value
  assign product_size_map = product.metafields.custom.sizemap.value
  assign product_media_reviews = product.metafields.custom.product_media_reviews.value | reverse
  assign product_parameter_and_icons = product.metafields.custom.product_parameter_icons.value
  assign product_send_accessories_icon = product.metafields.custom.product_send_accessories_icon.value
  assign product_accessories = product.metafields.custom.product_accessories.value

  assign product_left_swiper_width = 64
  assign product_main_swiper_width = 1024
  assign product_prameters_size = 45
  assign product_media_icon_height = 100

  assign product_left_swiper_class = "er-w-[64px] er-rounded-md er-cursor-pointer er-border-solid er-border-0 er-border-primary [&[class~='active']]:er-border-2 er-hidden xl:er-flex"
  assign product_main_swiper_class = 'swiper-slide er-object-cover er-aspect-[16/11] er-rounded-2xl'
  assign section_class = 'er-relative er-font-base er-max-w-screen-xl er-mx-auto er-flex er-justify-between er-px-12'

  if product_default_variant
    assign current_variant = product_default_variant
  endif

  assign product_delivery_time = current_variant.metafields.custom.delivery_time.value | default: product.metafields.custom.delivery_time.value
  assign swiper_of_variant = current_variant.metafields.custom.variant_image.value
  assign swiper_of_common = product.metafields.custom.product_common_images.value
  assign swiper = null | sort
  assign product_send_accessories_price = product_send_accessories_price | default: 16800

  if swiper_insert_index == blank
    assign swiper_insert_index = swiper_of_variant.count
  endif

  assign inserted = true
  for item in swiper_of_variant
    if forloop.index > swiper_insert_index and inserted
      assign inserted = false
      for item in swiper_of_common
        assign temp = item | sort
        assign swiper = swiper | concat: temp
      endfor
    endif
    assign temp = item | sort
    assign swiper = swiper | concat: temp
  endfor

  if swiper_insert_index >= swiper_of_variant.count and inserted
    for item in swiper_of_common
      assign temp = item | sort
      assign swiper = swiper | concat: temp
    endfor
  endif
-%}

{% if product.metafields.custom.h1 %}
  <h1 class="er-sr-only">{{ product.metafields.custom.h1 }}</h1>
{% else %}
  <h1 class="er-sr-only">{{ product.title }}</h1>
{% endif %}
{{
  swiper.first
  | image_url: width: 1024
  | preload_tag: as: 'image', type: 'image/webp', fetchpriority: 'high', media: '(min-width: 769px)'
}}
{{
  swiper.first
  | image_url: width: 640
  | preload_tag: as: 'image', type: 'image/webp', fetchpriority: 'high', media: '(max-width: 768px)'
}}
<section
  class="product-panel {{ section_class }} er-mt-24 er-pb-40 mb:er-flex-col mb:er-px-6 mb:er-mt-0 mb:er-pb-24"
  data-variant-id="{{ current_variant.id }}"
  data-swiper-insert-index="{{ swiper_insert_index }}"
  data-variant-swiper-size="{{ swiper_of_variant.count }}"
>
  <nav class="er-absolute er-top-[-50px]">
    <ol class="er-list-none er-m-0 er-p-0 er-flex er-items-center er-space-x-3 er-text-primary er-font-medium">
      <li>
        <a class="er-button er-button-text" href="/collections/e-bike-sale">E-Bikes</a>
      </li>
      <span>&gt;</span>
      <li>
        <span>{{ product.title }}</span>
      </li>
    </ol>
  </nav>
  <div class="er-flex-col er-shrink-0 er-space-y-6 left-images er-hidden xl:er-flex er-h-fit md:er-sticky md:er-top-28">
    {%- for variant_image in swiper -%}
      {{
        variant_image
        | image_url: width: product_left_swiper_width
        | image_tag: class: product_left_swiper_class, data-index: forloop.index, fetchpriority: 'low', loading: 'lazy'
      }}
    {%- endfor -%}
  </div>
  <div class="er-flex-1 er-pr-[4%] er-flex er-flex-col er-space-y-10 mb:er-px-0 er-h-fit xl:er-px-[5%] md:er-sticky md:er-top-28">
    {%- render 'product-panel-common', product: product, class: 'md:er-hidden' -%}
    <div
      class="er-aspect-[16/11] product-panel-swiper er-relative er-overflow-hidden er-rounded-2xl md:!er-mt-0"
      style="--swiper-theme-color: #000;"
    >
      <div class="swiper-wrapper">
        {%- for variant_image in swiper -%}
          {%- if forloop.index < 2 -%}
            {%- assign fetchpriority = 'high' -%}
            {%- assign preload = true -%}
            {%- assign loading = 'eager' -%}
          {%- else -%}
            {%- assign fetchpriority = 'low' -%}
            {%- assign preload = false -%}
            {%- assign loading = 'lazy' -%}
          {%- endif -%}
          {{
            variant_image
            | image_url: width: product_main_swiper_width
            | image_tag:
              widths: '640, 1024',
              sizes: '(max-width:768px) 0px, 1024px',
              class: product_main_swiper_class,
              data-index: forloop.index,
              fetchpriority: fetchpriority,
              loading: loading,
              preload: preload
          }}
        {%- endfor -%}
      </div>
      <div
        class="swiper-button-prev er-transition er-bg-[#ffffff80] er-rounded-lg after:er-text-5xl hover:er-opacity-70 er-select-none er-z-[1] mb:er-hidden"
      ></div>
      <div
        class="swiper-button-next er-transition er-bg-[#ffffff80] er-rounded-lg after:er-text-5xl hover:er-opacity-70 er-select-none er-z-[1] mb:er-hidden"
      ></div>
    </div>
    <div
      class="swiper-pagination md:er-hidden er-static !er-mt-4 !er-mb-[-15px] er-leading-none er-h-6 er-z-[1]"
      style="--swiper-pagination-color: #000;--swiper-pagination-bullet-size: 6px;"
    ></div>
    <div class="er-flex er-flex-col er-items-center er-text-center er-italic product-medias">
      <span class="text-size16 er-font-bold er-text-dark/80 mb:er-text-2xl">
        {{- product_media_reviews.first.text -}}
      </span>
      {{
        product_media_reviews.first.image
        | image_url: height: product_media_icon_height
        | image_tag: class: 'er-h-20 er-object-contain mb:er-h-16 mb:er-w-auto', data-index: '1'
      }}
    </div>
    {% if product_parameter_and_icons.count %}
      <div class="er-grid er-grid-cols-2 er-gap-y-8 mb:er-hidden lg:er-grid-cols-3">
        {%- for item in product_parameter_and_icons -%}
          <div class="er-flex er-items-center">
            {{
              item.image
              | image_url: width: product_prameters_size, height: product_prameters_size
              | image_tag: fetchpriority: 'low', loading: 'lazy'
            }}
            <span class="text-size14 er-ml-2">{{ item.text }}</span>
          </div>
        {%- endfor -%}
      </div>
    {% endif %}
  </div>
  <form
    method="post"
    accept-charset="UTF-8"
    action="/cart/add"
    data-productid="{{ product.id }}"
    id="product_form_{{ product.id }}"
    enctype="multipart/form-data"
    class="er-min-w-[400px] er-max-w-xl er-shrink-0 er-space-y-8 er-flex er-flex-col mb:er-min-w-0 mb:er-max-w-full"
  >
    <input type="hidden" name="id" data-product-id="{{ product.id }}" value="{{ current_variant.id }}">
    <input type="hidden" name="form_type" value="product">
    <input type="hidden" name="utf8" value="✓">
    {%- render 'product-panel-common', product: product, class: 'mb:er-hidden !er-mt-0' -%}
    {%- if product.metafields.custom.is_outlet.value -%}
      <ul class="er-shadow er-rounded-xl er-p-4 er-pl-12 marker:er-text-primary text-size16 er-space-y-4 er-text-2xl">
        <li>Used, Refurbish or Showroom Bike</li>
        <li>Small to none damage</li>
        <li>2-Year Warranty</li>
        <li>Not returnable</li>
      </ul>
    {%- endif -%}
    {% unless settings.hide_sale_countdown -%}
      {% render 'sale-v2' %}
    {%- endunless -%}
    {%- for option in product.options_with_values -%}
      <fieldset
        class="option er-border-none er-p-0 er-space-y-4"
        option="{{ option.name }}"
        position="{{ option.position }}"
      >
        <legend class="text-size18 er-font-bold mb:er-text-2xl">
          {{- option.name -}}
          -
          <span class="er-font-normal er-text-dark/70">
            {%- if option.position == 1 -%}
              {{ product_size_map[current_variant.options.first] }}
            {%- else -%}
              {{ current_variant.options.last }}
            {%- endif -%}
          </span>
        </legend>
        <div class="er-flex er-gap-5">
          {%- for option_value in option.values -%}
            <label
              {% if option.position == 1 -%}
                class="er-button er-button-dark er-px-6 text-size14 er-py-2 er-rounded-xl er-min-w-28{% unless option_value.name == current_variant.options.first %} er-button-outline{% endunless %}"
              {% else -%}
                data-style="{{ option_value }}"
                class="er-group er-w-14 er-h-14 er-rounded-full er-border-2 er-border-solid er-border-transparent er-cursor-pointer er-transition er-bg-[var(--product-option-color)] er-p-[2px] er-bg-clip-content [&[class~='active']]:er-border-[var(--product-option-color)] er-relative{% if option_value.name == current_variant.options.last %} active{% endif %}"
              {% endif %}
            >
              <input
                type="radio"
                id="{{ option_value }}"
                name="{{ option.name }}"
                value="{{ option_value }}"
                class="er-hidden"
              >
              <span
                {%- if option.position == 2 %}
                  class="mb:er-hidden group-hover:er-visible group-hover:er-opacity-100 after:er-border-x-transparent after:er-border-t-dark after:er-border-b-transparent after:er-border-8 after:er-border-solid after:er-content-[''] after:er-bottom-[-16px] after:er-absolute after:er-left-1/2 after:er-translate-x-[-50%] er-absolute er-bottom-[150%] er-left-1/2 er-translate-x-[-50%] er-bg-dark er-text-white er-px-6 er-py-2 er-rounded-full er-whitespace-nowrap er-opacity-0 er-invisible er-transition-opacity er-duration-300 text-size14 er-font-medium er-z-10"
                {%- endif -%}
              >
                {{- option_value -}}
              </span>
            </label>
          {%- endfor -%}
        </div>
      </fieldset>
    {%- endfor -%}
    {% if product_accessories.count %}
      <div class="er-flex er-flex-col er-border er-border-solid er-border-border er-rounded-lg er-p-4 accessories">
        <div class="text-size18 er-font-bold er-mt-2 er-mb-4 mb:er-text-2xl">Compatible Accessory</div>
        <label class="er-bg-border er-pl-2 mb:er-pl-1 er-pr-4 er-py-4 er-select-none er-pointer-events-none er-flex er-items-center peer-checked:er-bg-primary er-rounded-lg er-transition-colors er-gap-x-3">
          <input
            checked
            type="checkbox"
            name="id"
            style="width: 0;height: 0;margin: 0;appearance: none;accent-color: transparent;background-image: none;border: none;box-shadow: none;padding: 0;"
          >
          <img
            src="https://cdn.shopify.com/s/files/1/0583/5810/4213/files/25961.svg?v=1758174989"
            height="20"
            width="20"
            class="!er-min-w-8 mb:!er-min-w-6 mb:!er-max-w-6"
            alt=""
          >
          {{
            product_send_accessories_icon.image
            | image_url: width: 150
            | image_tag: class: 'er-max-w-24 mb:er-max-w-20', loading: 'lazy'
          }}
          <span class="text-size14 mb:er-text-xl">{{ product_send_accessories_icon.text }}</span>
          <span class="er-flex-1"></span>
          <div class="er-flex er-flex-col er-items-end">
            <span class="er-bg-primary text-size18 er-font-bold mb:er-text-2xl er-text-white er-rounded-lg er-px-3"
              >FREE</span
            >
            <del class="er-block text-size18 er-font-bold mb:er-text-2xl er-text-[#909090] er-mt-1">
              {{- product_send_accessories_price | money_without_trailing_zeros -}}
            </del>
          </div>
        </label>
        <div class="er-border-0 er-border-b er-border-solid er-border-b-border er-my-4 mb:er-my-3"></div>
        <label class="er-bg-border er-pl-2 mb:er-pl-1 er-pr-4 er-py-4 er-select-none er-pointer-events-none er-flex er-items-center peer-checked:er-bg-primary er-rounded-lg er-transition-colors er-gap-x-3">
          <input
            checked
            type="checkbox"
            name="id"
            style="width: 0;height: 0;margin: 0;appearance: none;accent-color: transparent;background-image: none;border: none;box-shadow: none;padding: 0;"
          >
          <img
            src="https://cdn.shopify.com/s/files/1/0583/5810/4213/files/25961.svg?v=1758174989"
            height="20"
            width="20"
            class="!er-min-w-8 mb:!er-min-w-6 mb:!er-max-w-6"
            alt=""
          >
          {{
            all_products['urtopia-portable-air-pump'].featured_image
            | image_url: width: 150
            | image_tag: class: 'er-max-w-24 mb:er-max-w-20', loading: 'lazy'
          }}
          <span class="text-size14 mb:er-text-xl">{{ all_products['urtopia-portable-air-pump'].title }}</span>
          <span class="er-flex-1"></span>
          <div class="er-flex er-flex-col er-items-end">
            <span class="er-bg-primary text-size18 er-font-bold mb:er-text-2xl er-text-white er-rounded-lg er-px-3"
              >FREE</span
            >
            <del class="er-block text-size18 er-font-bold mb:er-text-2xl er-text-[#909090] er-mt-1">
              {{- all_products['urtopia-portable-air-pump'].price | money_without_trailing_zeros -}}
            </del>
          </div>
        </label>
        <div class="er-border-0 er-border-b er-border-solid er-border-b-border er-my-4 mb:er-my-3"></div>
        {%- assign counter = 0 -%}
        {% for prod in product_accessories %}
          {%- if prod.available -%}
            {% if prod.variants.size > 1 %}
              {%- assign counter = counter | plus: 1 -%}
              <!-- 父级行：产品标题 - 与普通配件行保持一致 -->
              <div class="variant-tree {% if counter > 2 %}er-hidden{% endif %}">
                <label
                  class="variant-tree-toggle er-select-none er-p-1 er-pr-6 er-flex er-items-center er-rounded-lg er-transition-colors er-gap-x-4 mb:er-gap-x-3 er-cursor-pointer"
                  variant-id="{{ prod.first_available_variant.id }}"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="er-shrink-0 er-rotate-90 er-ml-2 er-transition-transform er-duration-300 variant-tree-arrow mb:er-ml-0"
                    height="32px"
                    viewBox="0 -960 960 960"
                    width="32px"
                    fill="#333"
                  >
                    <path d="M543.85-480.23 353.54-671.31l22.23-22.23 212.54 213.31-212.54 212.54-22.23-22.23 190.31-190.31Z"/>
                  </svg>
                  {{
                    prod.featured_image
                    | image_url: width: 120
                    | image_tag: class: 'er-max-w-24 mb:er-max-w-20', loading: 'lazy'
                  }}
                  <span class="text-size14 mb:er-text-xl">{{ prod.title }}</span>
                  <span class="er-flex-1"></span>
                  <span class="text-size18 er-font-bold mb:er-text-2xl">
                    {{- prod.price | money_without_trailing_zeros -}}
                  </span>
                </label>

                <!-- 子级行：variants 列表 - 目录树结构样式 -->
                <div class="variant-tree-children er-space-y-3 er-relative er-rounded-lg er-pl-10 er-ml-[8px] mb:er-ml-[4px] er-overflow-hidden er-transition-all er-duration-300">
                  <!-- 左侧竖线 -->
                  <span
                    class="er-absolute er-left-6 er-top-[-12px] er-bottom-10 mb:er-bottom-[22px] er-w-px er-bg-[#ddd]"
                  ></span>
                  {% for item in prod.variants %}
                    <label
                      class="er-select-none er-py-2 er-pr-6 er-rounded-lg er-flex er-items-center er-transition-colors er-gap-x-4 mb:er-gap-x-3 er-cursor-pointer variant-tree-item er-relative"
                      variant-id="{{ item.id }}"
                    >
                      <!-- 水平连接线 -->
                      <span class="er-absolute er-left-[-10px] er-top-1/2 er-w-8 mb:er-w-6 er-h-px er-bg-[#ddd]"></span>
                      <input
                        type="checkbox"
                        name="id"
                        value="{{ item.id }}"
                        class="peer"
                        style="width: 0;height: 0;margin: 0;appearance: none;accent-color: transparent;background-image: none;border: none;box-shadow: none;padding: 0;"
                      >
                      <img
                        src="https://cdn.shopify.com/s/files/1/0583/5810/4213/files/27315.svg?v=1758174989"
                        width="20"
                        height="20"
                        alt=""
                        data-status="unchecked"
                        class="!er-w-6 mb:!er-w-5"
                      >
                      <img
                        src="https://cdn.shopify.com/s/files/1/0583/5810/4213/files/25961.svg?v=1758174989"
                        width="20"
                        height="20"
                        alt=""
                        data-status="checked"
                        class="!er-w-6 mb:!er-w-5"
                        style="display: none;"
                      >
                      {{
                        item.featured_image
                        | image_url: width: 80
                        | image_tag: class: 'er-max-w-16 mb:er-max-w-14', loading: 'lazy'
                      }}
                      <span class="text-size14 mb:er-text-xl">{{ item.title }}</span>
                      <span class="er-flex-1"></span>
                      <span class="text-size16 er-font-bold mb:er-text-xl">
                        {{- item.price | money_without_trailing_zeros -}}
                      </span>
                    </label>
                  {% endfor %}
                </div>
              </div>
              <div
                class="er-border-0 er-border-b er-border-solid er-border-b-border er-my-4 mb:er-my-3 {% if counter > 2 %}er-hidden{% endif %}"
              ></div>
            {% else %}
              {%- assign counter = counter | plus: 1 -%}
              {%- assign variant = prod.first_available_variant -%}
              <label
                class="er-select-none er-p-1 er-pr-6 er-flex er-items-center peer-checked:er-bg-primary er-rounded-lg er-transition-colors er-gap-x-4 mb:er-gap-x-3 er-cursor-pointer {% if counter > 2 %}er-hidden{% endif %}"
                variant-id="{{ variant.id }}"
              >
                <input
                  type="checkbox"
                  name="id"
                  value="{{ variant.id }}"
                  class="peer"
                  style="width: 0;height: 0;margin: 0;appearance: none;accent-color: transparent;background-image: none;border: none;box-shadow: none;padding: 0;"
                >
                <img
                  src="https://cdn.shopify.com/s/files/1/0583/5810/4213/files/27315.svg?v=1758174989"
                  width="20"
                  height="20"
                  alt=""
                  data-status="unchecked"
                  class="!er-w-8 mb:!er-w-6"
                >
                <img
                  src="https://cdn.shopify.com/s/files/1/0583/5810/4213/files/25961.svg?v=1758174989"
                  width="20"
                  height="20"
                  alt=""
                  data-status="checked"
                  class="!er-w-8 mb:!er-w-6"
                  style="display: none;"
                >
                {{
                  prod.featured_image
                  | image_url: width: 120
                  | image_tag: class: 'er-max-w-24 mb:er-max-w-20', loading: 'lazy'
                }}
                <span class="text-size14 mb:er-text-xl">{{ prod.title }}</span>
                <span class="er-flex-1"></span>
                <span class="text-size18 er-font-bold mb:er-text-2xl">
                  {{- prod.price | money_without_trailing_zeros -}}
                </span>
              </label>
              <div
                class="er-border-0 er-border-b er-border-solid er-border-b-border er-my-4 mb:er-my-3 {% if counter > 2 %}er-hidden{% endif %}"
              ></div>
            {% endif %}
          {%- endif -%}
        {%- endfor -%}
        <span class="text-size14 er-text-primary er-cursor-pointer er-place-self-end showmore">Show more…</span>
      </div>
    {% endif %}
    <div class="er-flex er-flex-col er-space-y-5 buttons">
      <button
        class="er-button er-w-full er-py-5"
        data-text="Add To Cart"
        data-soldout="Sold Out"
        id="addToCart"
        data-product-id="{{ product.id }}"
        data-button-type="ATC"
        {%- unless current_variant.available -%}
          disabled
        {%- endunless -%}
      >
        {%- if current_variant.available -%}Add To Cart{%- else -%}Sold Out{%- endif -%}
      </button>
      <button
        class="er-button er-button-dark er-button-outline er-w-full er-py-1"
        data-button-type="klarna_check_out"
        {% unless current_variant.available %}
          disabled
        {% endunless %}
      >
        {% render 'icon-affirm-black' %}
        <span class="er-text-[#f472b6] er-text-3xl er-font-extrabold er-mt-2">Klarna.</span>
        <div class="er-flex er-flex-col text-size14 er-text-left">
          <span class="er-font-bold">0 APR Financing</span>
          <span
            >24 months,<span class="product-stages">
              {{- current_variant.price | divided_by: 24 | money_without_trailing_zeros -}}</span
            >/month</span
          >
        </div>
      </button>
    </div>
    <div class="er-border er-border-border er-border-solid er-p-4 er-rounded-2xl er-flex er-flex-col text-size14">
      <span class="product-delivery-time er-font-bold">{{ product_delivery_time }}</span>
      <span
        >Need help? Email
        <a href="mailto:support@newurtopia.com" class="er-button er-button-text">support@newurtopia.com</a>
      </span>
    </div>
    <div class="er-flex er-flex-col er-divide-y er-divide-border er-divide-solid er-divide-x-0">
      <div class="er-flex er-py-5 text-size14 er-justify-between er-cursor-pointer" data-dialog-id="SizesDialog">
        <span>Size & Fit</span><span>&gt;</span>
      </div>
      <div class="er-flex er-py-5 text-size14 er-justify-between er-cursor-pointer" data-dialog-id="SpecsDialog">
        <span>Technical Specs</span><span>&gt;</span>
      </div>
    </div>
    <div class="er-grid er-grid-cols-3 mb:er-pb-8">
      <div class="er-flex er-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 80 80" fill="none">
  <path d="M15.9167 13H64.0834C64.6917 13 65.2186 13.2233 65.6642 13.67C66.1103 14.1161 66.3334 14.6439 66.3334 15.2533C66.3334 15.8622 66.1103 16.3889 65.6642 16.8333C65.2186 17.2778 64.6917 17.5 64.0834 17.5H15.9167C15.3084 17.5 14.7811 17.2767 14.335 16.83C13.8895 16.3839 13.6667 15.8561 13.6667 15.2467C13.6667 14.6378 13.8895 14.1111 14.335 13.6667C14.7811 13.2222 15.3084 13 15.9167 13ZM17.5834 67C16.5972 67 15.7536 66.6492 15.0525 65.9475C14.3509 65.2464 14 64.4028 14 63.4167V46.6667H12.75C11.5834 46.6667 10.6389 46.2083 9.91668 45.2917C9.19446 44.375 8.97224 43.3611 9.25002 42.25L12.9167 27.9167C13.1006 27.1356 13.5247 26.4819 14.1892 25.9558C14.8536 25.4297 15.6239 25.1667 16.5 25.1667H63.5C64.3761 25.1667 65.1464 25.4297 65.8109 25.9558C66.4753 26.4819 66.8995 27.1356 67.0834 27.9167L70.75 42.25C71.0278 43.3611 70.8056 44.375 70.0834 45.2917C69.3611 46.2083 68.4167 46.6667 67.25 46.6667H66V64.75C66 65.3583 65.7767 65.8856 65.33 66.3317C64.8839 66.7772 64.3561 67 63.7467 67C63.1378 67 62.6111 66.7772 62.1667 66.3317C61.7222 65.8856 61.5 65.3583 61.5 64.75V46.6667H45.6667V63.4167C45.6667 64.4028 45.3161 65.2464 44.615 65.9475C43.9134 66.6492 43.0695 67 42.0834 67H17.5834ZM18.5 62.5H41.1667V46.6667H18.5V62.5ZM13.8334 42.1667H66.1667L63 29.6667H17L13.8334 42.1667Z" fill="#1A1A1A"/>
</svg>
        <span class="text-size12 er-font-medium er-ml-2">
          {{- settings.shop_count -}}
          <br>
          Bike Shops</span
        >
      </div>
      <div class="er-flex er-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 80 80" fill="none">
  <path d="M37.7084 72C36.9584 71.7778 36.2779 71.4166 35.6667 70.9166L18.0001 57.5833C17.1112 56.9166 16.4167 56.0797 15.9167 55.0725C15.4167 54.0653 15.1667 53.0133 15.1667 51.9166V15C15.1667 12.96 15.8512 11.2555 17.2201 9.88665C18.5884 8.51776 20.2929 7.83331 22.3334 7.83331H57.6667C59.7067 7.83331 61.4112 8.51776 62.7801 9.88665C64.149 11.2555 64.8334 12.96 64.8334 15V51.9166C64.8334 53.0133 64.5834 54.0653 64.0834 55.0725C63.5834 56.0797 62.889 56.9166 62.0001 57.5833L44.3334 70.9166C43.7223 71.4166 43.0417 71.7778 42.2917 72C41.5417 72.2222 40.7779 72.3333 40.0001 72.3333C39.2223 72.3333 38.4584 72.2222 37.7084 72ZM38.4167 67.3333C38.8612 67.7222 39.389 67.9166 40.0001 67.9166C40.6112 67.9166 41.139 67.7222 41.5834 67.3333L59.2501 54.015C59.5834 53.7372 59.8473 53.4178 60.0417 53.0566C60.2362 52.6955 60.3334 52.2928 60.3334 51.8483V15C60.3334 14.3333 60.0556 13.7222 59.5001 13.1666C58.9445 12.6111 58.3334 12.3333 57.6667 12.3333H22.3334C21.6667 12.3333 21.0556 12.6111 20.5001 13.1666C19.9445 13.7222 19.6667 14.3333 19.6667 15V51.8333C19.6667 52.2778 19.764 52.6805 19.9584 53.0416C20.1529 53.4028 20.4167 53.7222 20.7501 54L38.4167 67.3333ZM36.5001 41.9166L30.6667 36.0833C30.2173 35.6389 29.6881 35.4028 29.0792 35.375C28.4709 35.3472 27.9167 35.6111 27.4167 36.1666C26.9167 36.6666 26.6806 37.1944 26.7084 37.75C26.7362 38.3055 27.0001 38.8333 27.5001 39.3333L34.0001 45.75C34.7123 46.4722 35.5431 46.8333 36.4926 46.8333C37.442 46.8333 38.2779 46.4722 39.0001 45.75L52.5834 32.1666C53.0279 31.7222 53.2779 31.1944 53.3334 30.5833C53.389 29.9722 53.139 29.4166 52.5834 28.9166C52.0834 28.4166 51.5556 28.1805 51.0001 28.2083C50.4445 28.2361 49.9167 28.5 49.4167 29L36.5001 41.9166ZM38.4167 12.3333H19.6667H60.3334H38.4167Z" fill="#1A1A1A"/>
</svg>
        <span class="text-size12 er-font-medium er-ml-2"
          >2-Year<br>
          Warranty</span
        >
      </div>
      <div class="er-flex er-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 80 80" fill="none">
  <path d="M18.8332 71.5C16.7926 71.5 15.0882 70.8156 13.7198 69.4467C12.3509 68.0783 11.6665 66.3739 11.6665 64.3333V22C11.6665 19.96 12.3509 18.2556 13.7198 16.8867C15.0882 15.5178 16.7926 14.8333 18.8332 14.8333H22.8332V7.5H27.6665V14.8333H52.6665V7.5H57.1665V14.8333H61.1665C63.2065 14.8333 64.9109 15.5178 66.2798 16.8867C67.6487 18.2556 68.3332 19.96 68.3332 22V42.5L63.8332 47V34.3333H16.1665V64.3333C16.1665 65 16.4443 65.6111 16.9998 66.1667C17.5554 66.7222 18.1665 67 18.8332 67H37.2498L41.8332 71.5H18.8332ZM16.1665 29.8333H63.8332V22C63.8332 21.3333 63.5554 20.7222 62.9998 20.1667C62.4443 19.6111 61.8332 19.3333 61.1665 19.3333H18.8332C18.1665 19.3333 17.5554 19.6111 16.9998 20.1667C16.4443 20.7222 16.1665 21.3333 16.1665 22V29.8333ZM55.4165 73.3333L45.3332 63.3333L48.4998 60.1667L55.4998 67.1667L69.4998 53.0833L72.7498 56.1667L55.4165 73.3333Z" fill="#1A1A1A"/>
</svg>
        <span class="text-size12 er-font-medium er-ml-2"
          >14-Day<br>
          Trial</span
        >
      </div>
    </div>
    {% if product_parameter_and_icons.count %}
      <div class="er-grid er-grid-cols-2 er-gap-y-8 md:er-hidden">
        {%- for item in product_parameter_and_icons -%}
          <div class="er-flex er-items-center">
            {{ item.image | image_url: width: 40, height: 40 | image_tag: fetchpriority: 'low', loading: 'lazy' }}
            <span class="text-size12 er-font-medium er-ml-2">{{ item.text }}</span>
          </div>
        {%- endfor -%}
      </div>
    {% endif %}
  </form>
</section>
<section class="product-bar er-fixed er-inset-x-0 er-top-0 er-z-[-1] er-bg-white er-text-dark er-shadow er-translate-y-[-100%] er-transition er-opacity-0 er-duration-300 mb:er-top-auto mb:er-bottom-0 mb:er-translate-y-[100%]">
  <div class="{{ section_class }} er-h-28 er-flex er-items-center er-justify-between mb:er-px-6">
    <span class="er-text-4xl er-font-bold mb:er-hidden">{{ product.title }}</span>
    <div class="er-flex er-items-center mb:er-flex-row-reverse mb:er-justify-between mb:er-w-full">
      <div class="er-text-right">
        <div class="er-flex er-items-center er-justify-end">
          <span class="er-font-bold er-text-4xl product-price mb:er-text-3xl er-text-primary">
            {{- current_variant.price | money -}}
          </span>
          {% if current_variant.compare_at_price > current_variant.price %}
            <del class="er-text-3xl er-text-dark/70 er-ml-2 product-compare-at-price mb:er-text-2xl">
              {{- current_variant.compare_at_price | money -}}
            </del>
          {% endif %}
        </div>
        <div class="er-text-2xl">
          or as low as<span class="product-stages">
            {{- current_variant.price | divided_by: 24 | money_without_trailing_zeros -}}</span
          >/Month
        </div>
      </div>
      <span class="er-flex-1"></span>
      <a href="#product_form_{{ product.id }}" class="er-button er-ml-6 mb:er-ml-0">Order Now</a>
    </div>
  </div>
</section>
<style>
  #b2b > div {
    width: 500px;
    height: 150px;
    display: flex;
    align-items: center;
    background-color: #fff;
    border-radius: 15px;
    padding: 30px;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    position: relative;
  }

  #b2b > div .close {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 40px;
    color: #999;
    cursor: pointer;
    font-weight: 100;
    display: block;
    height: 40px;
    line-height: 40px;
    width: 40px;
    text-align: center;
  }

  @media (max-width: 767px) {
    #b2b > div {
      width: 84vw;
    }
  }
</style>
<dialog id="b2b">
  <div>
    To place an order, please contact our B2B team at:
    <a href="mailto:speed@newurtopia.com" class="my-link">speed@newurtopia.com</a>
    <span class="close">×</span>
  </div>
</dialog>
<script
  type="module"
>
  const product_variants = [
    {%- for variant in product.variants -%}
      {
        id: '{{ variant.id }}',
        title: '{{ variant.title }}',
        price: '{{ variant.price }}',
        compare_at_price: '{{ variant.compare_at_price }}',
        inventory_quantity: '{{ variant.inventory_quantity }}',
        available: {{ variant.available }},
        delivery_time: '{{ variant.metafields.custom.delivery_time.value | default: product.metafields.custom.delivery_time.value }}',
        images: [
          {%- for image in variant.metafields.custom.variant_image.value -%}
            {
              image_tag: '{{ image | image_url: width: product_main_swiper_width | image_tag: class: product_main_swiper_class, widths: "640, 1024", sizes: "(max-width:768px) 0px, 1024px" }}',
              image_url: '{{ image | image_url: width: product_left_swiper_width }}'
            },
          {%- endfor -%}
        ]
     },
    {%- endfor -%}
  ]

  // 当前variant
  let current_variant = product_variants.find(v => v.id === '{{ current_variant.id }}')

  // 属性和索引映射
  const product_options = {
    {%- for option in product.options_with_values -%}
      '{{ option.name }}': {{ option.position }},
    {%- endfor -%}
  }

  const product_medias = [
    {%- for item in product_media_reviews -%}
      {
        text: '{{ item.text }}',
        image: '{{ item.image | image_url: height: product_media_icon_height }}'
      },
    {%- endfor -%}
  ]

  const product_size_map = {{ product_size_map | json }}

  function removeSwiper (insert_index, variant_size) {
      const length = $('.left-images img').length
      let common_size = length - variant_size
      
      const indexs = []

      for (let i = 0; i < variant_size;i++) {
        indexs.push(i < insert_index ? i : i + common_size)
      }

      $('.product-panel .left-images').children().filter(i => indexs.includes(i)).remove()
      window.product_panel_swiper.removeSlide(indexs)
  }


  function insertSwiper (insert_index) {
      let images_length = current_variant.images.length
      $('.product-panel').attr('data-variant-swiper-size', images_length)
      const before = []
      const after = []

      for (let i = 0; i < images_length;i++) {
        if (i < insert_index) {
          before.push(current_variant.images[i])
        } else {
          after.push(current_variant.images[i])
        }
      }

      const fn_j = image => $(`<img width="64" src="${image.image_url}" class="{{ product_left_swiper_class }}">`)
      const fn_s = image => image.image_tag

      if (before.length) {
        $('.product-panel .left-images').prepend(before.map(fn_j))
        window.product_panel_swiper.prependSlide(before.map(fn_s).reverse())
      }

      if (after.length) {
        $('.product-panel .left-images').append(after.map(fn_j))
        window.product_panel_swiper.appendSlide(after.map(fn_s))
      }

      window.product_panel_swiper.slideTo(0)
      $('.product-panel .left-images > img').each((index, elem) => {
        $(elem).attr('data-index', index + 1).removeClass('active')
      })
  }


  function onVariantChange (name, value) {
    let title = current_variant.title.split(' / ')
    title[product_options[name] - 1] = value
    title = title.join(' / ')

    const find = product_variants.find(v => v.title === title)
    if (!find || !find.available) {
      $('.product-panel .buttons > button').attr('disabled', true)
      $('.product-panel #addToCart').text($('#addToCart').attr('data-soldout'))
    } else {
      $('.product-panel .buttons > button').attr('disabled', false)
      $('.product-panel #addToCart').text($('#addToCart').attr('data-text'))
    }

    current_variant = Object.assign({}, find)
    $('.product-panel').attr('data-variant-id', current_variant.id)
    replaceSearchValue('variant', current_variant.id)
    $('.product-panel input[name="id"]').val(current_variant.id)
    $('.product-panel .product-delivery-time').text(current_variant.delivery_time)

    if (current_variant.images && current_variant.images.length) {
      let variant_size = Number($('.product-panel').attr('data-variant-swiper-size'))
      let insert_index = Number($('.product-panel').attr('data-swiper-insert-index'))
      // remove
      removeSwiper(insert_index, variant_size)

      // insert
      insertSwiper(insert_index)
    }
  }

  // 父级点击展开/收缩子级variants
  $('.product-panel .variant-tree-toggle').on('click', function(e) {
    e.preventDefault();
    const tree = $(this).closest('.variant-tree');
    const children = tree.find('.variant-tree-children');
    const arrow = $(this).find('.variant-tree-arrow');
    
    if (children.hasClass('collapsed')) {
      // 展开
      children.removeClass('collapsed').css('max-height', children[0].scrollHeight + 'px');
      arrow.addClass('er-rotate-90');
    } else {
      // 收缩
      children.addClass('collapsed').css('max-height', '0');
      arrow.removeClass('er-rotate-90');
    }
  });

  $('.showmore').on('click', function() {
    $('.product-panel .accessories').find('.er-hidden').removeClass('er-hidden');
    $(this).remove();
  });

  $('.product-panel .accessories input[type="checkbox"].peer').on('change', function() {
    const label = $(this).closest('label');
    if ($(this).is(':checked')) {
      label.addClass('er-bg-border')
      label.find('img[data-status="unchecked"]').hide();
      label.find('img[data-status="checked"]').show();
    } else {
      label.removeClass('er-bg-border');
      label.find('img[data-status="unchecked"]').show();
      label.find('img[data-status="checked"]').hide();
    }
  });

  $('.product-panel .buttons > button').on('click', async function (e) {
    if (/\/[^\/]*-b2b/.test(window.location.pathname)) {
       console.log('路径中包含 -b2b 的段');
       showDialog(document.getElementById('b2b')).then(console.log).catch(console.log);


        e.preventDefault();   // 阻止默认行为（比如 form submit）
        e.stopPropagation();  // 阻止事件冒泡（不往父节点传）
        e.stopImmediatePropagation(); // 阻止当前元素上后续的所有事件绑定
        return false; // 等价于 preventDefault + stopPropagation（不总是完整）
    }
    
    const target = $(this)
    const cart = document.querySelector('cart-drawer')
    const items = []

    target.addClass('er-button-loading').attr('disabled', true)

    $('.product-panel .accessories input:checked').each((i, item) => {
      const id = $(item).closest('label').attr('variant-id');

        id && items.push({
          id,
          quantity: 1,
        });
    });

    items.push({ id: current_variant.id, quantity: 1 })

    try {
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        body: JSON.stringify({
          sections: cart.getSectionsToRender().map((section) => section.id).join(','),
          items
        }),
        headers: {
          'Content-Type': 'application/json',
        },
      }).then((res) => res.json())

      if ($(cart).hasClass('is-empty')) {
        $(cart).removeClass('is-empty')
      }

      if (res.items && res.sections && res.items.length) {
        cart.renderContents(res)
      }

      console.log(res)
    } catch (error) {
      console.log(error)
    } finally {
      target.removeClass('er-button-loading').attr('disabled', false)
      fetchBuried('websiteclick', location.pathname.split('/').pop(), { button: target.attr('data-button-type')  })
    }
  })

  $('.product-panel input[type="radio"]').on('change', function () {
      const target = $(this)
      const name = target.attr('name')
      const value = target.val()

      // 获取选中的值
      console.log(name, ': ', value)

      target.parent().removeClass('er-button-outline').siblings().addClass('er-button-outline')
      target.parent().addClass('active').siblings().removeClass('active')
      target.closest('.option').find('legend span').text(product_size_map[value] ? `${product_size_map[value]}` : value)
      onVariantChange(name, value)
  })

    $('.product-panel .left-images').on('click', 'img', function () {
      const index = Number($(this).attr('data-index'))
      $(this).addClass('active').siblings().removeClass('active')
      window.product_panel_swiper.slideTo(index - 1)
    })

    $('.product-panel div[data-dialog-id]').on('click', function () {
          showDialog(document.getElementById($(this).attr('data-dialog-id')))
    })

    window.product_panel_swiper = new Swiper('.product-panel .product-panel-swiper', {
          navigation: {
            nextEl: '.product-panel .product-panel-swiper .swiper-button-next',
            prevEl: '.product-panel .product-panel-swiper .swiper-button-prev',
          },
          preloadImages: false,
          spaceBetween: 10,
          slidesPerView: "auto",
          pagination: { el: '.product-panel .swiper-pagination' },
          on:{
              slideChange: function() {
                const index = this.realIndex + 1
                const loopIndex = this.realIndex % product_medias.length
                $('.product-panel .left-images').find(`img[data-index=${index}]`).addClass('active').siblings().removeClass('active')
                $('.product-panel .product-medias').find('img').attr('src', product_medias[loopIndex].image).removeAttr('srcset')
                $('.product-panel .product-medias').find('span').text(product_medias[loopIndex].text)
              },
          },
    })

    task(() => {
      let lastScrollTop = 0; // 记录上次滚动位置
      let isVisible = false; // 记录当前状态
      let ticking = false; // 防止 requestAnimationFrame 频繁执行
      const target = $('.product-bar');
      const threshold = screen.availHeight * 1.5; // 触发计算的阈值
      const isMobile = global_config.is_mobile; // 判断是否是移动端

      function updateNavbar(scrollTop) {
          if (isMobile) {
              // 📱 移动端逻辑：超过 threshold 就显示，以下隐藏
              if (scrollTop > threshold && !isVisible) {
                  target.css({ opacity: 1, zIndex: 99999, transform: 'translateY(0)' });
                  isVisible = true;
              } else if (scrollTop <= threshold && isVisible) {
                  target.css({  opacity: 0, zIndex: -1, transform: 'translateY(100%)' });
                  isVisible = false;
              }
          } else {
              // 💻 PC 端逻辑：滚动方向决定显示 / 隐藏
              const scrollingDown = scrollTop > lastScrollTop;
              if (scrollTop > threshold) {
                  if (scrollingDown && !isVisible) {
                      target.css({ opacity: 1, zIndex: 99999, transform: 'translateY(0)' });
                      isVisible = true;
                  } else if (!scrollingDown && isVisible) {
                      target.css({ opacity: 0, zIndex: -1, transform: 'translateY(-100%)' });
                      isVisible = false;
                  }
              } else if (isVisible) {
                  target.css({ opacity: 0, zIndex: -1, transform: 'translateY(-100%)' });
                  isVisible = false;
              }
          }

          lastScrollTop = scrollTop;
          ticking = false;
      }

      $(window).on('scroll', function () {
          const scrollTop = $(this).scrollTop();

          if (!ticking) {
              ticking = true;
              requestAnimationFrame(() => updateNavbar(scrollTop));
          }
      });
    })
</script>
