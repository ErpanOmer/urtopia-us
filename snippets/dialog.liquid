<script type="module">
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}',
      };

      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`,
      };

      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`,
      };

      window.accessibilityStrings = {
        imageAvailable: `{{ 'products.product.media.image_available' | t: index: '[index]' }}`,
        shareSuccess: `{{ 'general.share.success_message' | t }}`,
        pauseSlideshow: `{{ 'sections.slideshow.pause_slideshow' | t }}`,
        playSlideshow: `{{ 'sections.slideshow.play_slideshow' | t }}`,
  };
  window.addEventListener('load', () => {
    // 检测浏览器是否支持 <dialog>
      if (typeof HTMLDialogElement === "undefined") {
        // 动态加载 Polyfill 的样式和脚本
        const script = document.createElement("script");
        script.src = "{{ 'dialog-polyfill.js' | asset_url }}";
        script.onload = () => {
            document.querySelectorAll("dialog").forEach(dialog => {
            dialogPolyfill.registerDialog(dialog);
          });
        };
        
        document.head.appendChild(script);
      };
  });
</script>
<script type="module">
  fetch(window.location.pathname + '?sections=cart-drawer').then(r => r.json()).then(r => {
    document.body.insertAdjacentHTML('beforeend',r['cart-drawer']);
  })

  fetch(window.location.pathname + '?sections=footer').then(r => r.json()).then(r => {
    document.body.insertAdjacentHTML('beforeend',r['footer']);
  });
</script>
{% unless template.name == 'index' or template.name == 'product' %}
  <script type="module">
    const jq = window.jQuery || window.$;

    if (jq) {
      jq(function ($) {
        var $win = $(window);
        var $stickyHeader = $('sticky-header').first();
        var $headerSection = $('#shopify-section-header');
        var $motionTarget = $headerSection.length ? $headerSection : $stickyHeader;
        var hideThreshold = 200;
        var lastScrollTop = $win.scrollTop();
        var scrollDirection = 'down';
        var isHeaderVisible = true;
        var ticking = false;
        var stickyEl = $stickyHeader.get(0);

        if (!$stickyHeader.length) {
          return;
        }

        if (stickyEl) {
          stickyEl.preventHide = true;
          if (stickyEl.onScrollHandler) {
            window.removeEventListener('scroll', stickyEl.onScrollHandler);
          }
        }

        $motionTarget.css({
          transition: 'transform 0.48s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.36s ease',
          willChange: 'transform, opacity',
          transform: 'translate3d(0, 0, 0)',
          opacity: '1',
          backfaceVisibility: 'hidden'
        });

        function showHeader() {
          $headerSection.removeClass('shopify-section-header-hidden');
          if (isHeaderVisible) {
            $motionTarget.css('pointer-events', '');
            return;
          }

          isHeaderVisible = true;
          $motionTarget.css({
            transform: 'translate3d(0, 0, 0)',
            opacity: '1',
            pointerEvents: ''
          });
        }

        function hideHeader() {
          if (!isHeaderVisible) return;
          isHeaderVisible = false;
          $motionTarget.css({
            transform: 'translate3d(0, -110%, 0)',
            opacity: '0',
            pointerEvents: 'none'
          });
        }

        function updateHeaderState() {
          var currentTop = $win.scrollTop();
          var delta = currentTop - lastScrollTop;

          if (delta > 1) {
            scrollDirection = 'down';
          } else if (delta < -1) {
            scrollDirection = 'up';
          }

          if (currentTop <= hideThreshold) {
            showHeader();
          } else if (scrollDirection === 'up') {
            showHeader();
          } else {
            hideHeader();
          }

          lastScrollTop = currentTop;
          ticking = false;
        }

        function requestUpdate() {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(updateHeaderState);
        }

        $win.on('scroll.dialogSticky resize.dialogSticky', requestUpdate);
        updateHeaderState();
      });
    }
  </script>
{% endunless %}
