            </th>
            <td style="border-top: 1px solid #E6E6E6;" class="er-px-12 er-py-8 er-text-3xl er-text-gray-900 md:er-whitespace-nowrap er-bg-background mb:er-text-xl mb:er-px-4">
              2x faster
            </td>
            <td style="border-top: 1px solid #E6E6E6;" class="er-border-l er-border-gray-200 er-px-12 er-py-8 er-text-3xl er-text-gray-700 md:er-whitespace-nowrap mb:er-text-xl mb:er-px-4">
