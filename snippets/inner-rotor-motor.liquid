            </th>
            <th class="er-border-b er-border-l er-border-gray-200 er-px-12 er-py-8 er-text-left er-text-4xl er-font-semibold er-leading-tight er-text-gray-900 md:er-whitespace-nowrap md:er-flex md:er-items-baseline mb:er-text-xl mb:er-px-4">
