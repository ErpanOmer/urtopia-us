            {% render 'image', mb_src: "https://cdn.shopify.com/s/files/1/0583/5810/4213/files/20260331-111409_2_1.jpg?v=1775528827", src:'https://cdn.shopify.com/s/files/1/0583/5810/4213/files/20260331-111409_1_1.jpg?v=1775528827', class: "er-block" %}
    </div>

