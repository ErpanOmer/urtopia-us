       <img class="er-place-self-center mb:er-max-w-32" src="https://cdn.shopify.com/s/files/1/0583/5810/4213/files/df_1.png?v=1775115496" alt="Conventional Hub Motor" loading="lazy" width="150" height="150">
    </div>

    <div class="er-overflow-x-auto">
