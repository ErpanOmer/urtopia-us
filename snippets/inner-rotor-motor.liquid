              <span class="er-ml-1 er-text-gray-500">(Noticeably louder)</span>
            </td>
          </tr>

          <tr class="hover:er-bg-gray-50/70">
            <th style="border-top: 1px solid #E6E6E6;" class="er-bg-gray-50 er-px-12 er-py-8 er-text-left er-text-3xl er-font-semibold er-text-gray-500 er-whitespace-nowrap mb:er-hidden">
