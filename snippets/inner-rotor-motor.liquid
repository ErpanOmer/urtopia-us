            </td>
          </tr>

          <tr class="hover:er-bg-gray-50/70">
            <th style="border-top: 1px solid #E6E6E6;" class="er-bg-gray-50 er-px-12 er-py-8 er-text-left er-text-3xl er-font-semibold er-text-gray-500 er-whitespace-nowrap mb:er-hidden mb:er-px-4">
              Ride Feel
            </th>
            <td style="border-top: 1px solid #E6E6E6;" class="er-px-12 er-py-8 er-text-3xl er-text-gray-900 md:er-whitespace-nowrap er-bg-background mb:er-text-xl mb:er-px-4">
