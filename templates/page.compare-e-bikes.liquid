        { label: 'Fork', key: 'fork' },
        { label: 'Tires', key: 'tires' },
        { label: 'Display Type', key: 'display_type' },
    ]

    const fn = function () {
        $(this).closest('.dots').find('div').removeClass('active');
        $(this).addClass('active');

        $(this).closest('.er-aspect-square').find('img').attr('src', $(this).attr('data-image')).removeAttr('srcset').removeAttr('sizes').removeAttr('loading');
        $(this).closest('div[data-row-index]').find('a').attr('href', $(this).attr('data-url'));
        $(this).closest('.er-aspect-square').find('.text-size20.er-font-extrabold').text($(this).attr('data-price'));
    }

    $('div[data-row-index] select').on('change', function () {
        const value = $(this).val()
        const rowIndex = $(this).closest('div[data-row-index]').attr('data-row-index');

        const info = compare_infos[value];
        const template = document.getElementById(value);
        if (template) {
            const clone = template.content.cloneNode(true);
            $(`div[data-row-index="${rowIndex}"] > div:nth-of-type(2)`).replaceWith(clone);
            setTimeout(() => {
                $(`div[data-row-index="${rowIndex}"] .dots > div`).on('click', fn);
            }, 100);
        }

        $(`div[data-row-index="${rowIndex}"] a`).attr('href', info.url);
        fieldConfig.forEach((field, index) => {
            const $row = $(`div[data-row-index="${rowIndex}"] > div:nth-of-type(${index + 3})`);
            $row.find('span').eq(0).text(field.label);
            $row.find('span').eq(1).text(info[field.key] || '');
        });
    });

    $('.compare .dots > div').on('click', fn);
    $('div[data-row-index] select').each(function () {
        $(this).trigger('change');
    });
