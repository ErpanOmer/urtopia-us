<style>
  fieldset[option=Color] label[data-style="Glacier Blue"] {
    --product-option-color: #9ec0d1;
  }

  fieldset[option=Color] label[data-style="Urtopia Orange"] {
    --product-option-color: #FD4B17;
  }

   h1, h2, h3, h4 {
    color: inherit;
    margin: 0;
    display: block;
  }

  .TakeItEasywithFold1 .centeral-content .items>div{
    aspect-ratio:unset;
  }

.swiper-video {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 2; 
    cursor: pointer;
    transform: translate(-50%, -50%);
    opacity: 0;
  }
</style>
