{% liquid
  assign product = all_products['urtopia-chord-ebike']
  assign current_variant = product.selected_or_first_available_variant
%}

<script>
  console.log(JSON.parse(JSON.stringify({{ product | json }})))
  console.log(JSON.parse(JSON.stringify({{ current_variant | json }})))
</script>

<section class="er-max-w-screen-xl er-mx-auto er-flex er-justify-between er-px-12 er-m-48">
  <div class="er-w-24 er-shrink-0">
    <div class="er-aspect-video">
      {% for variant_image in current_variant.metafields.custom.variant_image.value %}
        {{ variant_image | image_url: width: 64 | image_tag }}
      {% endfor %}
    </div>
  </div>
  <div class="er-flex-1 er-px-[5%]">
    <div class="er-aspect-video">
      {% for variant_image in current_variant.metafields.custom.variant_image.value %}
        {{ variant_image | image_url: width: 640 | image_tag }}
      {% endfor %}
    </div>
  </div>
  <div class="er-min-w-[400px] er-shrink-0 er-space-y-8 er-flex er-flex-col">
    <h1>{{ product.title }}</h1>
    <span class="er-text-5xl product-price" data-price="{{ product.compare_at_price | money }}">
      {{- product.price | money -}}
    </span>
    {% for option in product.options_with_values %}
      <fieldset class="option er-border-none er-p-0"  option="{{ option.name }}">
        <legend>
          {{ option.name }} - <span>{{ option.selected_value }}</span>
        </legend>
        <div class="er-flex er-gap-6">
          {% for option_value in option.values %}
            <label class="er-inline-flex er-border er-border-black er-bg-dark er-py-4 er-px-12 er-pointer er-items-center er-justify-center er-white{% if option_value.selected %} active{% endif %}">
              <input
                type="radio"
                id="{{ option_value }}"
                name="{{ option.name }}"
                value="{{ option_value }}"
                class="er-hidden"
                {% if option_value.selected %}
                  checked
                {% endif %}
                data-variant-id="{{ option_value.variant.id }}"
                data-option-value-id="{{ option_value.id }}"
              >
              {% if option.position == 1 %}
                <span>{{ option_value }}</span>
              {% endif %}
            </label>
          {% endfor %}
        </div>
      </fieldset>
    {% endfor %}

    <div class="er-flex er-flex-col er-space-y-8">
      <button class="er-button er-w-full">Add To Cart</button>
      <button class="er-button er-button-dark er-w-full">Process Checkout</button>
    </div>
  </div>
</section>
