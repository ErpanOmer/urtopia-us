{% liquid
  assign product = all_products['urtopia-chord-ebike']
  assign variant = product.variants | where: 'id', 43694976663800 | first
%}

<script>
  console.log(JSON.parse(JSON.stringify({{ product | json }})))
  // console.log(JSON.parse(JSON.stringify({{  }})))
</script>

<section class="er-max-w-screen-xl er-mx-auto er-flex er-justify-between er-px-12 er-m-48">
  <div class="er-w-24 er-shrink-0">
    <div class="er-aspect-video">
      {% for variant_image in variant.metafields.custom.variant_image.value %}
        {{ variant_image | image_url: width: 64 | image_tag }}
      {% endfor %}
    </div>
  </div>
  <div class="er-flex-1 er-px-[5%]">
    <div class="er-aspect-video">
      {% for variant_image in variant.metafields.custom.variant_image.value %}
        {{ variant_image | image_url: width: 640 | image_tag }}
      {% endfor %}
    </div>
  </div>
  <div class="er-min-w-[400px] er-shrink-0 er-space-y-8 er-flex er-flex-col">
    <h1>{{ product.title }}</h1>
    <span class="er-text-5xl" data-price="{{ product.compare_at_price | money }}">{{ product.price | money }}</span>
    {% for option in product.options_with_values %}
      <div class="options">
        <div>{{ option.name }} - <span>Fit for 5’3’’~6’1’’</span></div>
        {% for value in option.values %}
            <input type="radio" id="{{ value }}" name="{{ option.name }}" value="{{ value }}">
        {% endfor %}
      </div>
    {% endfor %}

    <div class="er-flex er-flex-col er-space-y-8">
      <button class="er-button er-w-full">Add To Cart</button>
      <button class="er-button er-button-dark er-w-full">Process Checkout</button>
    </div>
  </div>
</section>
