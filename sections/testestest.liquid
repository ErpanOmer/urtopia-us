{% liquid
  assign product = all_products['urtopia-carbon-1-pro-ebike']
  assign current_variant = product.selected_or_first_available_variant
%}

<script>
  console.log(JSON.parse(JSON.stringify({{ product | json }})))
  console.log(JSON.parse(JSON.stringify({{ current_variant | json }})))
  console.log(JSON.parse(JSON.stringify({{ product.options_by_name | json }})))
</script>

<section class="er-max-w-screen-xl er-mx-auto er-flex er-justify-between er-px-12 er-m-48">
  <div class="er-w-24 er-shrink-0">
    <div class="er-aspect-video">
      {% for variant_image in current_variant.metafields.custom.variant_image.value %}
        {{ variant_image | image_url: width: 64 | image_tag }}
      {% endfor %}
    </div>
  </div>
  <div class="er-flex-1 er-px-[5%]">
    <div class="er-aspect-video">
      {% for variant_image in current_variant.metafields.custom.variant_image.value %}
        {{ variant_image | image_url: width: 640 | image_tag }}
      {% endfor %}
    </div>
  </div>
  <div class="er-min-w-[400px] er-shrink-0 er-space-y-8 er-flex er-flex-col">
    <h1>{{ product.title }}</h1>
    <span class="er-text-5xl product-price" data-price="{{ product.compare_at_price | money }}">
      {{- product.price | money -}}
    </span>
    {% for option in product.options_with_values %}
      <fieldset class="option er-border-none er-p-0 er-space-y-4"  option="{{ option.name }}">
        <legend>
          {{ option.name }} - <span>{{ option.selected_value }}</span>
        </legend>
        <div class="er-flex er-gap-4">
          {% for option_value in option.values %}
            <label class="er-button er-button-dark er-px-12 er-text-2xl er-py-2{% unless option_value.selected %} er-button-outline{% endunless %}">
              <input
                type="radio"
                id="{{ option_value }}"
                name="{{ option.name }}"
                value="{{ option_value }}"
                class="er-hidden"
                {% if option_value.selected %}
                  checked
                {% endif %}
                data-variant-id="{{ option_value.variant.id }}"
                data-option-value-id="{{ option_value.id }}"
              >
              <span>{% if option.position == 1 %}
                {{ option_value }}
              {% endif %}</span>
            </label>
          {% endfor %}
        </div>
      </fieldset>
    {% endfor %}

    <div class="er-flex er-flex-col er-space-y-8">
      <button class="er-button er-w-full">Add To Cart</button>
      <button class="er-button er-button-dark er-w-full">Process Checkout</button>
    </div>
  </div>
</section>

<script>
  // 获取所有的 radio 输入
  const radios = document.querySelectorAll('input[type="radio"]');
  const current_variant = {
    {% for option in product.options_with_values %}
      '{{ option.name }}': '{{ option.selected_value }}',
    {% endfor %}
    id: '{{ current_variant.id }}',
    title: '{{ current_variant.title }}',
    price: '{{ current_variant.price }}',
    compare_at_price: '{{ current_variant.compare_at_price }}',
    inventory_quantity: '{{ current_variant.inventory_quantity }}',
    available: {{ current_variant.available }}
  }

  const product_variants = [
    {% for variant in product.variants %}
      {
        id: '{{ variant.id }}',
        title: '{{ variant.title }}',
        price: '{{ variant.price }}',
        compare_at_price: '{{ variant.compare_at_price }}',
        inventory_quantity: '{{ variant.inventory_quantity }}',
        available: {{ variant.available }}
     },
    {% endfor %}
  ]

  const product_options = {
    {% for option in product.options_with_values %}
      '{{ option.name }}': {{ option.position }},
    {% endfor %}
  }


  function onVariantChange (name, value) {
    let title = current_variant.title.split(' / ')
    title[product_options[name] - 1] = value
    title = title.join(' / ')

    const find = product_variants.find(v => v.title === title)

    console.log(find)
  }

  // 监听每个 radio 的 change 事件
  radios.forEach(radio => {
    radio.addEventListener('change', (event) => {
      const target = $(event.target)
      const name = target.attr('name')
      const value = target.val()

      // 获取选中的值
      console.log(name, ': ', value)

      target.parent().removeClass('er-button-outline').siblings().addClass('er-button-outline')
      target.closest('.option').find('legend span').text(value)
      onVariantChange(name, value)
    });
  });
</script>
