      <svg xmlns="http://www.w3.org/2000/svg" height="24" viewBox="0 -960 960 960" width="24" fill="#fff"><path d="M665.08-450H180v-60h485.08L437.23-737.85 480-780l300 300-300 300-42.77-42.15L665.08-450Z"/></svg>
    </a>
  </div>
</div>
<script type="module">
  const jq = window.jQuery || window.$;
  if (!jq) {
    console.warn('pf-home: jQuery not found');
  } else {
    jq(function ($) {
      var $win = $(window);
      var $topStyle = $('#pf-home-top-style');
      var $stickyHeader = $('sticky-header').first();
      var $headerSection = $('#shopify-section-header');
      var $headerWrapper = $stickyHeader.find('.header-wrapper').first();
      var $mobileDrawerDetails = $stickyHeader.find('#Details-menu-drawer-container').first();
      var $motionTarget = $headerSection.length ? $headerSection : $stickyHeader;
      var styleThreshold = 100;
      var hideThreshold = 200;
      var lastScrollTop = $win.scrollTop();
      var isHeaderVisible = true;
      var ticking = false;
      var isMenuMode = false;
      var preMenuState = null;
      var lastAppliedTopStyleActive = true;
      var lastAppliedHeaderWhite = false;
      var stickyEl = $stickyHeader.get(0);

      if (!$stickyHeader.length) {
        return;
      }

      if (!$headerWrapper.length) {
        $headerWrapper = $('.header-wrapper').first();
      }

      if (stickyEl) {
        stickyEl.preventHide = true;
        if (stickyEl.onScrollHandler) {
          window.removeEventListener('scroll', stickyEl.onScrollHandler);
        }
      }

      $motionTarget.css({
        transition: 'transform 0.48s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.36s ease',
        willChange: 'transform, opacity',
        transform: 'translate3d(0, 0, 0)',
        opacity: '1',
        backfaceVisibility: 'hidden'
      });

      $headerWrapper.css('transition', 'none');

      function toggleTopStyle(isActive) {
        if (!$topStyle.length) return;
        lastAppliedTopStyleActive = !!isActive;
        $topStyle.attr('media', isActive ? 'all' : 'not all');
      }

      function toggleHeaderWhite(isWhite) {
        lastAppliedHeaderWhite = !!isWhite;
        if (isWhite) {
          $motionTarget.css('background-color', '#fff');
          $headerWrapper.css('background-color', '#fff');
        } else {
          $motionTarget.css('background-color', '');
          $headerWrapper.css('background-color', '');
        }
      }

      function showHeader() {
        if (isHeaderVisible) {
          $headerSection.removeClass('shopify-section-header-hidden');
          return;
        }
        isHeaderVisible = true;
        $headerSection.removeClass('shopify-section-header-hidden');
        $motionTarget.css({
          transform: 'translate3d(0, 0, 0)',
          opacity: '1',
          pointerEvents: ''
        });
      }

      function hideHeader() {
        if (!isHeaderVisible) return;
        isHeaderVisible = false;
        $motionTarget.css({
          transform: 'translate3d(0, -110%, 0)',
          opacity: '0',
          pointerEvents: 'none'
        });
      }

      function isSubmenuOpen() {
        var desktopSubmenuOpen = $stickyHeader.find('header-menu details[open]').length > 0;
        var mobileDrawerOpen = false;

        if ($mobileDrawerDetails.length) {
          var drawerHasOpenAttr = $mobileDrawerDetails.is('[open]');
          var drawerIsAnimatingOpen = $mobileDrawerDetails.hasClass('menu-opening');
          var headerHasMenuOpenClass = $headerSection.hasClass('menu-open');

          // Theme core removes [open] with a ~400ms delay on close. Treat drawer as closed
          // once close starts (menu-opening/menu-open removed) to avoid restore lag.
          mobileDrawerOpen = drawerHasOpenAttr && (drawerIsAnimatingOpen || headerHasMenuOpenClass);
        }

        return desktopSubmenuOpen || mobileDrawerOpen;
      }

      function onSubmenuStateChange() {
        var menuOpen = isSubmenuOpen();

        if (menuOpen && !isMenuMode) {
          preMenuState = {
            topStyleActive: lastAppliedTopStyleActive,
            headerWhite: lastAppliedHeaderWhite,
            headerVisible: isHeaderVisible
          };
          isMenuMode = true;
          toggleTopStyle(false);
          toggleHeaderWhite(true);
          showHeader();
          return;
        }

        if (!menuOpen && isMenuMode) {
          isMenuMode = false;
          if (preMenuState) {
            toggleTopStyle(preMenuState.topStyleActive);
            toggleHeaderWhite(preMenuState.headerWhite);
            if (preMenuState.headerVisible) {
              showHeader();
            } else {
              hideHeader();
            }
          }
          preMenuState = null;
          lastScrollTop = $win.scrollTop();
        }
      }

      function updateHeaderState() {
        var currentTop = $win.scrollTop();
        var topStyleActive = currentTop <= styleThreshold;
        var isScrollingUp = currentTop < lastScrollTop;
        var isScrollingDown = currentTop > lastScrollTop;

        onSubmenuStateChange();
        if (isMenuMode) {
          lastScrollTop = currentTop;
          ticking = false;
          return;
        }

        toggleTopStyle(topStyleActive);
        toggleHeaderWhite(!topStyleActive);

        if (currentTop <= hideThreshold) {
          showHeader();
        } else if (isScrollingUp) {
          showHeader();
        } else if (isScrollingDown) {
          hideHeader();
        }

        lastScrollTop = currentTop;
        ticking = false;
      }

      function requestUpdate() {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateHeaderState);
      }

      $(document).on('toggle.pfHomeStickyMenu', 'sticky-header header-menu details', function () {
        onSubmenuStateChange();
      });

      $(document).on('click.pfHomeStickyMenu', 'sticky-header header-menu details > summary', function () {
        window.setTimeout(onSubmenuStateChange, 0);
      });

      $(document).on('toggle.pfHomeStickyMenu', 'sticky-header #Details-menu-drawer-container', function () {
        onSubmenuStateChange();
      });

      $(document).on('click.pfHomeStickyMenu', 'sticky-header .header__icon--menu.header__icon--summary', function () {
        window.setTimeout(onSubmenuStateChange, 0);
      });

      $(document).on('click.pfHomeStickyMenu', 'sticky-header .menu-drawer__close-button', function () {
        window.setTimeout(onSubmenuStateChange, 0);
      });

      if ($mobileDrawerDetails.length) {
        var mobileDrawerEl = $mobileDrawerDetails.get(0);
        mobileDrawerEl.addEventListener('toggle', onSubmenuStateChange);

        var mobileDrawerObserver = new MutationObserver(function () {
          onSubmenuStateChange();
        });
        mobileDrawerObserver.observe(mobileDrawerEl, {
          attributes: true,
          attributeFilter: ['open']
        });
      }

      $win.on('scroll.pfHomeSticky resize.pfHomeSticky', requestUpdate);
      updateHeaderState();
    });
  }
</script>
{% render 'quiz-dialog' %}
