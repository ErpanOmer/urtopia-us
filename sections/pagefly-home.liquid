<style id="pf-home-top-style" media="all">
  .header-wrapper.gradient {
      background: transparent;
  }

  .header-wrapper.gradient .header__inline-menu > ul > li > a,
  .header-wrapper.gradient .header__inline-menu > ul > li > header-menu > details > summary > span,
  .header-wrapper.gradient .header__inline-menu > ul > li > header-menu > details > summary > span + svg {
    color: #fff;
  }

  .header>.header__heading-link svg {
    fill: #fff;
  }

  .header__icons a {
    color: #fff;
  }

  .header__icon span {
    color: #fff;
  }

  .header__icons a > svg,
  .header__icon span > svg {
    opacity: 1;
  }
</style>

